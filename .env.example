# Copy to .internal/.env and fill in your values.
# Only needed for integration tests — unit tests don't require a database.

# Local PostgreSQL (Unix socket)
# POSTGRES_URL=postgresql:///dqlens_test?host=/tmp

# PostgreSQL (TCP)
# POSTGRES_URL=postgresql://user:pass@localhost:5432/dqlens_test

# PostgreSQL (RDS or remote)
# POSTGRES_URL=postgresql://user:pass@your-host.rds.amazonaws.com:5432/dev
